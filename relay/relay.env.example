# Copy to /etc/pg-lockstep/relay.env and edit locally.
# Do not commit real DSNs, Slack tokens, or private channel IDs.

PG_LOCKSTEP_RELAY_DSN=postgresql:///postgres
PG_LOCKSTEP_LOG_LEVEL=INFO

# Optional Slack forwarding. Leave unset to print events only.
PG_LOCKSTEP_SLACK_BOT_TOKEN=xoxb-your-token-here
PG_LOCKSTEP_SLACK_CHANNEL=C0123456789
